# Ejemplo de variables de entorno. NO subir un .env real al repo.
# Copiar/editar según el rol que corra cada máquina.

# --- Nodo de servicio (service/index.js) ---
# Puerto del nodo: M_A=50051, M_B=50052, M_C=50053
PORT=50051
# URL de la base de datos (máquina M_B). En M_B usar http://localhost:4000
DB_URL=http://IP_B:4000

# --- Web-server / balanceador (web-server/index.js, corre en M_A) ---
# PORT=3000
# Lista de nodos por IP LAN, separados por comas
# NODES=IP_A:50051,IP_B:50052,IP_C:50053
